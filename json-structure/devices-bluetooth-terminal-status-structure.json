{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-structure/devices-bluetooth-terminal-status-structure.json",
  "name": "BluetoothTerminalStatus",
  "description": "Status of the bluetooth terminal",
  "type": "object",
  "properties": {
    "SerialNumber": {
      "description": "Serial Number",
      "type": "string",
      "example": "string"
    },
    "SoftwareVersion": {
      "description": "Software Version",
      "type": "string",
      "example": "string"
    },
    "DeviceType": {
      "description": "Device Type",
      "enum": [
        "CHIPPER_2X",
        "COTS_DEVICE",
        "VERIFONE_P400",
        "WISEPAD_3",
        "WISEPOS_E"
      ],
      "type": "string",
      "example": "CHIPPER_2X"
    },
    "Status": {
      "description": "Device Status",
      "enum": [
        "Not_Connected",
        "Connecting",
        "Connected",
        "Online",
        "Offline"
      ],
      "type": "string",
      "example": "Not_Connected"
    },
    "BatteryLevel": {
      "description": "Indication of the battery level from 0 to 1",
      "type": "float",
      "nullable": true,
      "example": 1.0
    },
    "UpdateTime": {
      "description": "Last time the status was updated",
      "type": "datetime",
      "example": "2026-06-02T12:00:00Z"
    },
    "ReaderId": {
      "description": "ReaderId for Stripe Terminal",
      "type": "string",
      "example": "500123"
    }
  }
}