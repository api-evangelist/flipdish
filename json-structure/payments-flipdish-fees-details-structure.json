{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-structure/payments-flipdish-fees-details-structure.json",
  "name": "FlipdishFeesDetails",
  "description": "Fees breakdown",
  "type": "object",
  "properties": {
    "OnlineSalesFees": {
      "description": "Fees on online sales",
      "type": "double",
      "example": 12.5
    },
    "CashSalesFees": {
      "description": "Fees on cash sales",
      "type": "double",
      "example": 12.5
    },
    "PosSalesFees": {
      "description": "Fees of POS sales",
      "type": "double",
      "example": 12.5
    },
    "TotalSalesFees": {
      "description": "Total online and cash sales",
      "type": "double",
      "example": 12.5
    },
    "OnlineSalesRefundedFees": {
      "description": "Fees on refunds for online sales",
      "type": "double",
      "example": 12.5
    },
    "CashSalesRefundedFees": {
      "description": "Fees on refunds for cash sales",
      "type": "double",
      "example": 12.5
    },
    "PosSalesRefundedFees": {
      "description": "Fees on refunds for POS sales",
      "type": "double",
      "example": 12.5
    },
    "SalesFeesVat": {
      "description": "VAT on sales fees",
      "type": "double",
      "example": 12.5
    },
    "TotalFees": {
      "description": "Total fees",
      "type": "double",
      "example": 12.5
    }
  }
}