{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-structure/orders-refund-structure.json",
  "name": "Refund",
  "description": "Refund",
  "type": "object",
  "properties": {
    "RefundReason": {
      "description": "Refund reason",
      "type": "string",
      "example": "string"
    },
    "RefundAmount": {
      "description": "Refund amount",
      "minimum": 0,
      "type": "double",
      "example": 12.5
    },
    "NotifyCustomer": {
      "description": "If true, the system sends notification to the customer about the refund",
      "type": "boolean",
      "example": true
    }
  },
  "required": [
    "RefundAmount",
    "NotifyCustomer"
  ]
}