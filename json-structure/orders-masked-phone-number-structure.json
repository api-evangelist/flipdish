{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-structure/orders-masked-phone-number-structure.json",
  "name": "MaskedPhoneNumber",
  "description": "Represents a masked phone number",
  "type": "object",
  "properties": {
    "IsEnabled": {
      "description": "Defines if the feature is enabled",
      "type": "boolean",
      "example": true
    },
    "PhoneNumber": {
      "description": "Defines the phone number to call",
      "type": "string",
      "example": "+353000000000"
    },
    "Code": {
      "description": "Defines the code to enter",
      "type": "string",
      "example": "string"
    }
  }
}