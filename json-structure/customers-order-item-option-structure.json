{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-structure/customers-order-item-option-structure.json",
  "name": "OrderItemOption",
  "description": "Order item option",
  "type": "object",
  "properties": {
    "Metadata": {
      "description": "Metadata",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "MenuItemOptionPublicId": {
      "description": "Public id of the Menu Item Option",
      "type": "uuid",
      "example": "00000000-0000-0000-0000-000000000000"
    },
    "MenuItemOptionId": {
      "description": "Menu item option identifier",
      "type": "int32",
      "example": 500123
    },
    "IsMasterOptionSetItem": {
      "description": "Is master option set item",
      "type": "boolean",
      "example": true
    },
    "Name": {
      "description": "Name",
      "type": "string",
      "example": "Example Name"
    },
    "Price": {
      "description": "Price",
      "type": "double",
      "example": 12.5
    },
    "TaxAmount": {
      "description": "Tax currency amount",
      "type": "double",
      "example": 12.5
    },
    "MenuItemOptionDisplayOrder": {
      "description": "Menu item option display order",
      "type": "int32",
      "example": 1
    },
    "MenuItemOptionSetDisplayOrder": {
      "description": "Menu item option set display order",
      "type": "int32",
      "example": 1
    },
    "DepositReturnFee": {
      "description": "Deposit return fee",
      "type": "double",
      "nullable": true,
      "example": 12.5
    }
  }
}