{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-structure/marketing-push-notification-response-structure.json",
  "name": "PushNotificationResponse",
  "description": "Push Notification",
  "type": "object",
  "properties": {
    "Sent": {
      "description": "Sent",
      "type": "boolean",
      "example": true
    },
    "ScheduledPushNotificationId": {
      "description": "Push notification identifier",
      "type": "int32",
      "example": 500123
    },
    "ScheduledTime": {
      "description": "UTC Time at which to send the push notification",
      "type": "datetime",
      "example": "2026-06-02T12:00:00Z"
    },
    "Title": {
      "description": "Title of the notification",
      "type": "string",
      "example": "string"
    },
    "Message": {
      "description": "Message of the notification",
      "type": "string",
      "example": "string"
    }
  },
  "required": [
    "Message"
  ]
}