    "Name": {
      "description": "The name of the promotion",
      "type": "string",
      "example": "Example Name"
    },
    "PromotionAwards": {
      "description": "The items that this promotion will award",
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/PromotionAward"
      },
      "example": []
    }
  }
}