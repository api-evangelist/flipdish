{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-schema/apps-white-label-asset-model-schema.json",
  "title": "WhiteLabelAssetModel",
  "description": "White label asset model",
  "type": "object",
  "properties": {
    "WhiteLabelAssetId": {
      "format": "int32",
      "description": "White label asset ID",
      "type": "integer",
      "example": 500123
    },
    "WhiteLabelConfigId": {
      "format": "int32",
      "description": "White label configuration ID",
      "type": "integer",
      "example": 500123
    },
    "FilePath": {
      "description": "File path",
      "type": "string",
      "example": "string"
    },
    "Url": {
      "description": "Asset URL",
      "type": "string",
      "example": "https://api.flipdish.co/example"
    },
    "TsUpdate": {
      "format": "date-time",
      "description": "Timestamp update",
      "type": "string",
      "example": "2026-06-02T12:00:00Z"
    }
  }
}