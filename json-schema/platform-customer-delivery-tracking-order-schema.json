        "UAH",
        "UZS",
        "VND",
        "MOP",
        "TWD",
        "BMD"
      ],
      "type": "string",
      "example": "EUR"
    },
    "Latitude": {
      "format": "double",
      "description": "Customer Location Latitude",
      "type": "number",
      "example": 1.0
    },
    "Longitude": {
      "format": "double",
      "description": "Customer Location Longitude",
      "type": "number",
      "example": 1.0
    },
    "Placed": {
      "format": "date-time",
      "description": "Order placed time",
      "type": "string",
      "example": "2026-06-02T12:00:00Z"
    },
    "RequestedFor": {
      "format": "date-time",
      "description": "Order requested for",
      "type": "string",
      "example": "2026-06-02T12:00:00Z"
    },
    "DriverId": {
      "format": "int32",
      "description": "Driver Id",
      "type": "integer",
      "nullable": true,
      "example": 500123
    },
    "DriverName": {
      "description": "Driver Name",
      "type": "string",
      "example": "Example Name"
    },
    "DriverImage": {
      "description": "Driver Image",
      "type": "string",
      "example": "string"
    },
    "EstimatedMinutesForDelivery": {
      "format": "int32",
      "description": "",
      "type": "integer",
      "example": 1
    }
  }
}