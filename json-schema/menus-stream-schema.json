{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-schema/menus-stream-schema.json",
  "title": "Stream",
  "description": "Stream schema from Flipdish API - Menus.",
  "type": "object",
  "properties": {
    "CanRead": {
      "type": "boolean",
      "readOnly": true,
      "example": true
    },
    "CanSeek": {
      "type": "boolean",
      "readOnly": true,
      "example": true
    },
    "CanTimeout": {
      "type": "boolean",
      "readOnly": true,
      "example": true
    },
    "CanWrite": {
      "type": "boolean",
      "readOnly": true,
      "example": true
    },
    "Length": {
      "format": "int64",
      "type": "integer",
      "readOnly": true,
      "example": 1
    },
    "Position": {
      "format": "int64",
      "type": "integer",
      "example": 1
    },
    "ReadTimeout": {
      "format": "int32",
      "type": "integer",
      "example": 1
    },
    "WriteTimeout": {
      "format": "int32",
      "type": "integer",
      "example": 1
    }
  }
}