{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-schema/catalog-pending-menu-changes-summaries-schema.json",
  "title": "PendingMenuChangesSummaries",
  "description": "Pending menu changes summaries",
  "type": "object",
  "properties": {
    "MenuId": {
      "format": "int32",
      "description": "Menu id",
      "type": "integer",
      "example": 500123
    },
    "TotalPendingChanges": {
      "format": "int32",
      "description": "Sum of pending changes per menu id",
      "type": "integer",
      "example": 12.5
    }
  }
}