      "example": "Example Name"
    },
    "SummaryTotalPayout": {
      "format": "double",
      "type": "number",
      "example": 12.5
    },
    "SummaryRevenue": {
      "format": "double",
      "type": "number",
      "example": 1.0
    },
    "SummaryCashRevenue": {
      "format": "double",
      "type": "number",
      "example": 1.0
    },
    "SummaryTotalFlipdishFees": {
      "format": "double",
      "type": "number",
      "example": 12.5
    },
    "SummaryAdjustments": {
      "format": "double",
      "type": "number",
      "example": 1.0
    },
