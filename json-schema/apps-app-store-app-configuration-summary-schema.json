{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-schema/apps-app-store-app-configuration-summary-schema.json",
  "title": "AppStoreAppConfigurationSummary",
  "description": "AppStoreAppConfigurationSummary schema from Flipdish API - Apps.",
  "type": "object",
  "properties": {
    "Id": {
      "type": "string",
      "example": "500123"
    },
    "AppId": {
      "type": "string",
      "example": "500123"
    },
    "IsEnabled": {
      "type": "boolean",
      "example": true
    },
    "Stores": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/ConfiguredStore"
      },
      "example": []
    },
    "ConfigurationType": {
      "enum": [
        "ExternalLink",
        "FlipdishHosted"
      ],
      "type": "string",
      "example": "ExternalLink"
    },
    "StoreSelectorType": {
      "enum": [
        "None",
        "Single",
        "Multiple"
      ],
      "type": "string",
      "example": "None"
    },
    "Internal": {
      "type": "boolean",
      "example": true
    },
    "AppStoreAppId": {
      "type": "string",
      "example": "500123"
    },
    "Name": {
      "type": "string",
      "example": "Example Name"
    },
    "Description": {
      "type": "string",
      "example": "string"
    },
    "Logo": {
      "type": "string",
      "example": "string"
    },
    "DeveloperName": {
      "type": "string",
      "example": "Example Name"
    }
  },
  "required": [
    "Id",
    "AppId",
    "IsEnabled",
    "Stores",
    "ConfigurationType",
    "StoreSelectorType",
    "Internal",
    "AppStoreAppId",
    "Name",
    "Description"
  ]
}