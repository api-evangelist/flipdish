      "format": "int32",
      "description": "SmsConversationItemId.",
      "type": "integer",
      "example": 500123
    },
    "Direction": {
      "description": "Direction.",
      "type": "string",
      "example": "string"
    },
    "From": {
      "description": "From.",
      "type": "string",
      "example": "string"
    },
    "Text": {
      "description": "Text.",
      "type": "string",
      "example": "string"
    },
    "TsSentReceivedUtc": {
      "format": "date-time",
      "description": "TsSentReceivedUtc.",
      "type": "string",
      "example": "2026-06-02T12:00:00Z"
    }
  }
}