{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-schema/customers-user-sms-chat-item-schema.json",
  "title": "UserSmsChatItem",
  "description": "An SMS conversation item for admin user chat.",
