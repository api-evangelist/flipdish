{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/flipdish/refs/heads/main/json-schema/orders-masked-phone-number-schema.json",
  "title": "MaskedPhoneNumber",
  "description": "Represents a masked phone number",
  "type": "object",
  "properties": {
    "IsEnabled": {
      "description": "Defines if the feature is enabled",
      "type": "boolean",
      "example": true
    },
    "PhoneNumber": {
      "description": "Defines the phone number to call",
      "type": "string",
      "example": "+353000000000"
    },
    "Code": {
      "description": "Defines the code to enter",
      "type": "string",
      "example": "string"
    }
  }
}